            "text_color": "#6b7280",
            "typography_typography": "custom",
            "typography_font_size": {"unit": "rem", "size": 1.05},
            "typography_line_height": {"unit": "em", "size": 1.6},
            "width": {"unit": "px", "size": 650},
            "margin": {"unit": "px", "top": "0", "right": "auto", "bottom": "0", "left": "auto", "isLinked": false}
          }
        }
      ]
    }
  ]
