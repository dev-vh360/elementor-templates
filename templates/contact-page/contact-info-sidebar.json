              "id": "ct_info_emergency_text",
              "elType": "widget",
              "widgetType": "text-editor",
              "settings": {
                "editor": "<p>If you are experiencing a medical or mental health emergency, please contact your local emergency services or call your healthcare provider immediately.</p>",
                "text_color": "#6b7280",
                "typography_typography": "custom",
                "typography_font_size": {"unit": "rem", "size": 0.9},
                "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}
              }
            }
          ]
