            "typography_font_size": {"unit": "rem", "size": 0.9},
            "typography_font_weight": "700",
            "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "4", "left": "0", "isLinked": false}
          }
        },
        {
          "id": "ct_info_services_val",
          "elType": "widget",
          "widgetType": "text-editor",
          "settings": {
            "editor": "<p>Mental Health Therapy<br>Medical Consultations<br>Virtual Appointments</p>",
            "text_color": "#6b7280",
            "typography_typography": "custom",
            "typography_font_size": {"unit": "rem", "size": 0.95},
            "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "0", "left": "0", "isLinked": false}
          }
        },
        {
          "id": "ct_info_emergency_box",
          "elType": "container",
          "settings": {
            "_background_background": "classic",
            "_background_color": "#eef6ff",
            "border_border": "solid",
            "border_width": {"unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "1", "isLinked": true},
            "border_color": "#dbeafe",
            "border_radius": {"unit": "px", "top": "16", "right": "16", "bottom": "16", "left": "16", "isLinked": true},
            "padding": {"unit": "px", "top": "18", "right": "18", "bottom": "18", "left": "18", "isLinked": true},
            "margin": {"unit": "px", "top": "30", "right": "0", "bottom": "0", "left": "0", "isLinked": false},
            "width": {"unit": "%", "size": 100},
            "flex_direction": "column",
            "align_items": "flex-start"
