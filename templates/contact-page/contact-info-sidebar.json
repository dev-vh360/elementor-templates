          "elements": [
            {
              "id": "ct_info_emergency_title",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "Need Immediate Help?",
                "header_size": "h6",
                "align": "left",
                "title_color": "#1f2937",
