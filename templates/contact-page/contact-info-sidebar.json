{
  "version": "0.4",
  "title": "Contact Page - Info Sidebar",
  "type": "section",
  "content": [
    {
      "id": "ct_info_card",
      "elType": "container",
      "settings": {
        "_background_background": "classic",
        "_background_color": "#ffffff",
        "border_border": "solid",
        "border_width": {"unit": "px", "top": "1", "right": "1", "bottom": "1", "left": "1", "isLinked": true},
        "border_color": "#e5e7eb",
        "border_radius": {"unit": "px", "top": "22", "right": "22", "bottom": "22", "left": "22", "isLinked": true},
        "box_shadow_box_shadow_type": "yes",
        "box_shadow_box_shadow": {"horizontal": 0, "vertical": 18, "blur": 40, "spread": 0, "color": "rgba(0,0,0,0.08)"},
        "padding": {"unit": "px", "top": "28", "right": "28", "bottom": "28", "left": "28", "isLinked": true},
        "flex_direction": "column",
        "align_items": "flex-start"
      },
      "elements": [
        {
          "id": "ct_info_h2",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Contact Information",
            "header_size": "h2",
            "align": "left",
            "title_color": "#1f2937",
            "typography_typography": "custom",
            "typography_font_size": {"unit": "rem", "size": 1.5},
            "typography_font_weight": "700",
            "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "20", "left": "0", "isLinked": false}
          }
        },
        {
          "id": "ct_info_email_label",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Email",
            "header_size": "h6",
            "align": "left",
            "title_color": "#1f2937",
            "typography_typography": "custom",
            "typography_font_size": {"unit": "rem", "size": 0.9},
            "typography_font_weight": "700",
            "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "4", "left": "0", "isLinked": false}
          }
        },
        {
          "id": "ct_info_email_val",
          "elType": "widget",
          "widgetType": "text-editor",
          "settings": {
            "editor": "<p>support@virtualhealthdemo.com</p>",
            "text_color": "#6b7280",
            "typography_typography": "custom",
            "typography_font_size": {"unit": "rem", "size": 0.95},
            "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "22", "left": "0", "isLinked": false}
          }
        },
        {
          "id": "ct_info_phone_label",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Phone",
            "header_size": "h6",
