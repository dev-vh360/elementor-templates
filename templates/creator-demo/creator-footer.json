{
  "version": "0.4",
  "title": "Creator Demo - Footer",
  "type": "footer",
  "content": [
    {
      "id": "footer_outer",
      "elType": "container",
      "settings": {
        "background_background": "classic",
        "background_color": "#0b1020",
        "border_border": "none",
        "border_top_border": "solid",
        "border_top_width": {"unit": "px", "size": 1},
        "border_top_color": "rgba(255,255,255,0.12)",
        "padding": {"unit": "px", "top": "48", "right": "24", "bottom": "48", "left": "24", "isLinked": false},
        "content_width": "boxed",
        "boxed_width": {"unit": "px", "size": 1180}
      },
      "elements": [
        {
          "id": "footer_content",
          "elType": "container",
          "settings": {
            "flex_direction": "row",
            "justify_content": "space-between",
            "align_items": "center",
            "_mobile_flex_direction": "column",
            "_mobile_align_items": "center",
            "_mobile_text_align": "center",
            "_mobile_flex_gap": {"unit": "px", "column": "0", "row": "24"}
          },
          "elements": [
            {
              "id": "footer_left",
              "elType": "container",
              "settings": {
                "flex_direction": "column"
              },
              "elements": [
                {
                  "id": "footer_brand",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "Jay Carter Live",
                    "header_size": "p",
                    "title_color": "#f8fafc",
                    "typography_typography": "custom",
                    "typography_font_size": {"unit": "px", "size": 17},
                    "typography_font_weight": "700",
                    "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "8", "left": "0", "isLinked": false}
                  }
                },
                {
                  "id": "footer_tagline",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "Your direct line to exclusive content.",
                    "header_size": "p",
                    "title_color": "#b6c2d9",
                    "typography_typography": "custom",
                    "typography_font_size": {"unit": "px", "size": 14}
                  }
                }
              ]
            },
            {
              "id": "footer_links",
              "elType": "container",
              "settings": {
                "flex_direction": "row",
                "flex_gap": {"unit": "px", "column": "28", "row": "0"}
              },
              "elements": [
                {
                  "id": "footer_link1",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "Privacy",
                    "header_size": "p",
                    "title_color": "#b6c2d9",
                    "typography_typography": "custom",
                    "typography_font_size": {"unit": "px", "size": 14},
                    "_hover_title_color": "#f8fafc"
                  }
                },
                {
                  "id": "footer_link2",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "Terms",
                    "header_size": "p",
                    "title_color": "#b6c2d9",
                    "typography_typography": "custom",
                    "typography_font_size": {"unit": "px", "size": 14},
                    "_hover_title_color": "#f8fafc"
                  }
                },
                {
                  "id": "footer_link3",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "Contact",
                    "header_size": "p",
                    "title_color": "#b6c2d9",
                    "typography_typography": "custom",
                    "typography_font_size": {"unit": "px", "size": 14},
                    "_hover_title_color": "#f8fafc"
                  }
                }
              ]
            },
            {
              "id": "footer_copyright",
              "elType": "widget",
              "widgetType": "heading",
              "settings": {
                "title": "© 2026 Jay Carter Live",
                "header_size": "p",
                "title_color": "#b6c2d9",
                "typography_typography": "custom",
                "typography_font_size": {"unit": "px", "size": 14}
              }
            }
          ]
        }
      ]
    }
  ]
}
