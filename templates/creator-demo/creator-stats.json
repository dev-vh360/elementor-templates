{
  "version": "0.4",
  "title": "Creator Demo - Stats Band",
  "type": "section",
  "content": [
    {
      "id": "stats_outer",
      "elType": "container",
      "settings": {
        "background_background": "classic",
        "background_color": "#0b1020",
        "padding": {"unit": "px", "top": "0", "right": "24", "bottom": "80", "left": "24", "isLinked": false},
        "content_width": "boxed",
        "boxed_width": {"unit": "px", "size": 1180}
      },
      "elements": [
        {
          "id": "stats_band",
          "elType": "container",
          "settings": {
            "background_background": "gradient",
            "background_color": "#7c3aed",
            "background_color_b": "#06b6d4",
            "background_gradient_angle": {"unit": "deg", "size": 135},
            "border_radius": {"unit": "px", "top": "24", "right": "24", "bottom": "24", "left": "24", "isLinked": true},
            "padding": {"unit": "px", "top": "40", "right": "40", "bottom": "40", "left": "40", "isLinked": true},
            "box_shadow_box_shadow_type": "yes",
            "box_shadow_box_shadow": {"horizontal": 0, "vertical": 24, "blur": 60, "spread": 0, "color": "rgba(0,0,0,0.35)"},
            "width": {"unit": "%", "size": 100},
            "container_type": "grid",
            "grid_columns_grid": {"size": 4, "unit": "fr"},
            "gap": {"unit": "px", "column": "32", "row": "0"},
            "_tablet_grid_columns_grid": {"size": 2, "unit": "fr"},
            "_mobile_grid_columns_grid": {"size": 1, "unit": "fr"}
          },
          "elements": [
            {
              "id": "stat1",
              "elType": "container",
              "settings": {
                "flex_direction": "column",
                "align_items": "center",
                "text_align": "center"
              },
              "elements": [
                {
                  "id": "stat1_num",
                  "elType": "widget",
                  "widgetType": "heading",
                  "settings": {
                    "title": "2,400+",
                    "header_size": "p",
                    "align": "center",
                    "title_color": "#ffffff",
                    "typography_typography": "custom",
                    "typography_font_size": {"unit": "rem", "size": 2.8},
                    "typography_font_weight": "800",
                    "typography_line_height": {"unit": "em", "size": 1},
                    "margin": {"unit": "px", "top": "0", "right": "0", "bottom": "8", "left": "0", "isLinked": false}
                  }
